import java.util.Arrays;

public class Array {
    public static void main(String[] args) {
        int[] numbers = {5, 3, 8, 1, 2};
        int[] other = {5, 3, 8, 1, 2};
        // красиво печатает массив но не его адрес
        System.out.println(Arrays.toString(numbers));
        // сортирует массив по возрастанию
        Arrays.sort(numbers);
        System.out.println("После сортировки: " + Arrays.toString(numbers));
        // быстро ищет индекс элемента
        int index = Arrays.binarySearch(numbers, 5);
        System.out.println("Индекс числа 5: " + index);
        // проверка, одинаково ли содержимое и порядок элементов
        boolean isEqual = Arrays.equals(numbers, other);
        System.out.println("Массивы равны? " + isEqual);
        // сравнивает массивы лексикографически
        int comparison = Arrays.compare(new int[]{1, 2}, new int[]{1, 3});
        System.out.println("Результат сравнения: " + comparison);
    }
}
