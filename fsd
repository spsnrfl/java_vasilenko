import java.util.Scanner;
import java.io.File;
import java.io.FileNotFoundException;

public class FileScannerDemo {
    public static void main(String[] args) {
        // путь к файлу
        File file = new File("data.txt");

        // использование try-with-resources для авто закрытия сканера
        try (Scanner scanner = new Scanner(file)) {
            System.out.println("чтение данных из файла");

            // проверка есть ли в файле данные для чтения
            while (scanner.hasNextLine()) {
                String line = scanner.nextLine();
                System.out.println("считано: " + line);
            }

        } catch (FileNotFoundException e) {
            System.err.println("ошибка: файл не найден!");
        }
    }
}
