public class PracticeOne {
    // поля класса автоматически получают нулевые значения
    byte defaultByte;
    short defaultShort;
    int defaultInt;
    long defaultLong;
    float defaultFloat;
    double defaultDouble;
    char defaultChar;
    boolean defaultBoolean; // В Java пишем boolean, а не bool

    public void runPractice() {
        // локальные переменные обязательно инициализация
        byte b = 10;
        short s = 100;
        int i = 1000;
        long l = 10000L;
        float f = 1.2f;
        double d = 1.234;
        char c = 'A';
        boolean boolVal = true;

        // примеры вывода
        System.out.println("все типы данных");
        // примеры со значениями (локальные)
        System.out.println("byte: " + b);
        System.out.println("short: " + s);
        System.out.println("int: " + i);
        System.out.println("long: " + l);
        System.out.println("float: " + f);
        System.out.println("double: " + d);
        System.out.println("char: " + c);
        System.out.println("boolean: " + boolVal);

        System.out.println("\nНулевые значения (члены класса)");
        // поля класса
        System.out.println("byte (default): " + defaultByte);
        System.out.println("int (default): " + defaultInt);
        System.out.println("float (default): " + defaultFloat);
        System.out.println("char (default): [" + defaultChar + "] (пусто)");
        System.out.println("boolean (default): " + defaultBoolean);
    }

    public static void main(String[] args) {
        PracticeOne practice = new PracticeOne();
        practice.runPractice();
    }
}
